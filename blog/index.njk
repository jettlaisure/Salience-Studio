---
layout: null
title: "Blog — Salience Studio"
description: "Practical guides on SEO, LLM visibility, web design, brand strategy, press coverage, and email marketing for product-based and e-commerce brands."
permalink: "/blog/"
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://salience.studio/blog/">
  <link rel="canonical" href="https://salience.studio/blog/">
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="/css/reset.css?v=2">
  <link rel="stylesheet" href="/css/variables.css?v=2">
  <link rel="stylesheet" href="/css/global.css?v=2">
  <link rel="stylesheet" href="/css/blog.css?v=1">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>

  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <a href="/index.html" class="nav-wordmark">SALIENCE</a>
    <div class="nav-links">
      <a href="/deliverables.html">WORK</a>
      <a href="/services.html">SERVICES</a>
      <a href="/blog/" class="active">BLOG</a>
      <a href="/faq.html">FAQ</a>
      <a href="/contact.html">CONTACT</a>
    </div>
    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <div class="nav-overlay" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <button class="nav-close" aria-label="Close menu">CLOSE</button>
    <a href="/deliverables.html">WORK</a>
    <a href="/services.html">SERVICES</a>
    <a href="/blog/">BLOG</a>
    <a href="/faq.html">FAQ</a>
    <a href="/contact.html">CONTACT</a>
  </div>

  <main id="main">

    <div class="blog-header">
      <div class="blog-header-inner">
        <p class="section-label">Salience Studio</p>
        <h1 class="blog-title">THE BLOG</h1>
        <p class="blog-sub">Practical guides on SEO, LLM visibility, brand strategy, web design, press, and e-commerce marketing — for product brands that want to grow without social ads.</p>
      </div>
    </div>

    <div class="blog-list-wrapper">
      <div class="blog-list">
        {% for post in collections.posts %}
        <a href="{{ post.url }}" class="blog-card">
          <div class="blog-card-inner">
            <div class="blog-card-meta">
              <span class="blog-card-category">{{ post.data.category }}</span>
              <span class="blog-card-time">{{ post.data.readingTime }} min read</span>
            </div>
            <h2 class="blog-card-title">{{ post.data.title }}</h2>
            <p class="blog-card-desc">{{ post.data.description }}</p>
            <span class="blog-card-cta">Read article →</span>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="footer-wordmark">SALIENCE</span>
      </div>
      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-nav-col">
          <span class="footer-nav-label">NAVIGATE</span>
          <a href="/deliverables.html">Work</a>
          <a href="/services.html">Services</a>
          <a href="/blog/">Blog</a>
          <a href="/faq.html">FAQ</a>
          <a href="/contact.html">Contact</a>
        </div>
        <div class="footer-nav-col">
          <span class="footer-nav-label">CONTACT</span>
          <a href="mailto:hello@salience.studio">hello@salience.studio</a>
        </div>
      </nav>
    </div>
    <div class="footer-base">
      <span>© 2026 Salience Studio</span>
    </div>
  </footer>

  <script src="/js/nav.js" defer></script>
</body>
</html>
